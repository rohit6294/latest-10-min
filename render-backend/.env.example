# Base64-encoded Firebase service account JSON
# Generate: Firebase Console > Project Settings > Service Accounts > Generate new private key
# Then: cat serviceAccount.json | base64 -w 0   (or PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes('serviceAccount.json')))
FIREBASE_SERVICE_ACCOUNT_B64=

# Gupshup WhatsApp credentials (for /whatsapp/webhook endpoint)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=
GUPSHUP_SOURCE_NUMBER=

# Origins allowed to call this backend (comma-separated). e.g. https://min-rescue.web.app,http://localhost:5173
ALLOWED_ORIGINS=*

# Render auto-sets PORT; leave blank locally to default to 3000
PORT=
